# GridPath — environment variables
#
# Copy to .env.local and fill in. ALL are optional: with none set, the app runs
# on free OSM data + a deterministic clean-energy plan. Each key upgrades a piece.

# Anthropic API key — turns on the Claude-generated clean-energy plan.
# Without it, the advisor uses a transparent local fallback plan.
ANTHROPIC_API_KEY=

# Optional: override the model (defaults to claude-opus-4-8).
# CLAUDE_MODEL=claude-opus-4-8

# Google Maps key (server-side) — used for:
#   - Geocoding / autocomplete (falls back to OSM Nominatim if unset)
#   - Google Solar API: REAL rooftop solar potential per address
#     (enable "Solar API" + "Geocoding API" on the key in Google Cloud Console)
GOOGLE_MAPS_API_KEY=

# Google Maps key (client-side) — turns the map into a Google PHOTOREALISTIC 3D
# map. Without it, the app uses a clean 2D CARTO basemap. Enable "Map Tiles API"
# + "Maps JavaScript API" on this key. Can be the same key as above.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Twilio — turns on the "Call me about this location" button, which places an
# outbound voice call that speaks an AI briefing about the selected location.
# All three are required for calling; the rest of the app works without them.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# A voice-capable number on your Twilio account, in E.164 (e.g. +16282981759).
TWILIO_FROM_NUMBER=

# NVIDIA NIM API key — powers CONVERSATIONAL follow-up questions on the call.
# With this + PUBLIC_BASE_URL set, the caller can ask questions and NVIDIA
# Nemotron answers them (Twilio handles speech-to-text). Without it, the call is
# a one-way spoken briefing. Get a key at build.nvidia.com.
NVIDIA_API_KEY=
# Optional overrides (defaults shown):
# NVIDIA_LLM_URL=https://integrate.api.nvidia.com/v1
# NVIDIA_LLM_MODEL=nvidia/llama-3.3-nemotron-super-49b-v1.5

# Public HTTPS base URL Twilio can reach for the speech webhook (/api/voice).
# Required for conversational mode. In local dev, expose port 3000/3001 with a
# tunnel (e.g. `cloudflared tunnel --url http://localhost:3001`) and paste the
# https URL here. In production, your deployed origin (e.g. https://gridpath.app).
PUBLIC_BASE_URL=

# ---- Crypto payments (USDC on Base + Polygon, paid directly to the merchant) ----
#
# Postgres connection — REQUIRED for crypto checkout (orders + replay protection).
# Set automatically when you connect the Neon (or Vercel Postgres) integration on
# Vercel. Without it, the pay endpoints return 503 and the rest of the app works.
POSTGRES_URL=

# Optional dedicated RPC endpoints (recommended for production reliability).
# Without these, public RPCs are used (fine for low volume).
# Server-side (payment verification):
# RPC_BASE=https://base-mainnet.g.alchemy.com/v2/YOUR_KEY
# RPC_POLYGON=https://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY
# Client-side (wallet transport) — must be NEXT_PUBLIC_:
# NEXT_PUBLIC_RPC_BASE=
# NEXT_PUBLIC_RPC_POLYGON=

# ---- Xerberus token risk grade (the AAA–D badge on the pay screen) ----
# Free key from ms@xerberus.io. Key stays server-side. Without these the badge
# simply doesn't render (no "Unrated" noise).
XERBERUS_API_KEY=
XERBERUS_USER_EMAIL=deonmenezescodes@gmail.com

# ---- Xerberus V7 MCP — the Clean-Connect Pool investment-risk panel ----
# Richer risk data (graded ratings + percentiles, liquidity exit clocks, the
# historical scenario library) behind the "Fund it through the Clean-Connect
# Pool" panel on the estimate screen. Enterprise MCP key (sk-xbus-ro-…), stays
# server-side. Without it the panel falls back to bundled fixtures (still demos).
XERBERUS_MCP_KEY=
# Optional override (default shown):
# XERBERUS_MCP_URL=https://mcp.xerberus.io/enterprise/mcp
